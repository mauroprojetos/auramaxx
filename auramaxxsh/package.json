{
  "name": "auramaxx",
  "version": "0.0.20",
  "description": "Securely share passwords, API keys and wallets with your agent.",
  "keywords": [
    "onepassword",
    "ai-agent",
    "openclaw",
    "claude",
    "codex",
    "secrets",
    "credentials",
    "mcp",
    "cli",
    "automation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aura-Industry/auramaxx.git"
  },
  "main": "apps/desktop-electron/main.js",
  "bin": {
    "auramaxx": "./bin/auramaxx.js",
    "aura": "./bin/auramaxx.js"
  },
  "files": [
    "bin/",
    ".next/",
    "!.next/cache/",
    "src/server/",
    "!src/server/tests/",
    "!src/server/test-data/",
    "!src/server/vitest.config.ts",
    "!src/server/node_modules/",
    "shared/",
    "src/",
    "!src/__tests__/",
    "!src/internal/",
    "!src/internal/**",
    "!src/node_modules/",
    "public/",
    "!public/*.dmg",
    "!public/*.exe",
    "!public/*.AppImage",
    "!public/*.snap",
    "!public/*.deb",
    "!public/*.rpm",
    "!public/*.blockmap",
    "prisma/",
    "!prisma/dev.db",
    "!prisma/dev.db-journal",
    "!prisma/**/*.db",
    "!prisma/**/*.db-journal",
    "scripts/add-app.js",
    "skills/",
    "docs/",
    "!docs/internal/",
    "!docs/internal/**",
    "!docs/specs/",
    "!docs/specs/**",
    "start.sh",
    "tsconfig.json",
    "next.config.ts",
    "tailwind.config.ts",
    "postcss.config.mjs"
  ],
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true })\"",
    "postinstall": "prisma generate --schema ./prisma/schema.prisma",
    "build": "next build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/server/tsconfig.json",
    "typecheck:server": "tsc --noEmit -p src/server/tsconfig.json",
    "prepack": "npm run build",
    "auramaxx": "node ./bin/auramaxx.js",
    "auramaxx:dev": "node ./bin/auramaxx.js start --dev",
    "auramaxx:debug": "node ./bin/auramaxx.js --debug",
    "aura": "node ./bin/auramaxx.js",
    "test": "vitest run --config src/server/vitest.config.ts",
    "test:ai": "vitest run --config src/server/tests/ai-integration/vitest.config.ts",
    "test:setup": "vitest run --config src/server/tests/setup-integration/vitest.config.ts",
    "test:ai:live": "vitest run --config src/server/tests/ai-integration/vitest.live.config.ts",
    "test:watch": "vitest --config src/server/vitest.config.ts",
    "test:coverage": "vitest run --config src/server/vitest.config.ts --coverage",
    "test:cli": "vitest run --config src/server/vitest.config.ts tests/cli/",
    "test:e2e": "vitest run --config src/server/vitest.config.ts tests/e2e.test.ts",
    "test:ui": "vitest run --config src/__tests__/vitest.config.ts",
    "test:ui:watch": "vitest --config src/__tests__/vitest.config.ts",
    "test:e2e-agent:smoke": "vitest run --config src/server/vitest.config.ts tests/e2e-agent/**/*.test.ts",
    "test:runtime-agent-smoke": "vitest run --config src/server/vitest.config.ts tests/runtime-agent-smoke.test.ts",
    "test:e2e-agent:nightly": "vitest run --config src/server/vitest.config.ts tests/e2e-agent/**/*.test.ts",
    "test:cd:cli": "vitest run --config src/server/vitest.config.ts tests/sandbox/cli.test.ts",
    "test:cd:cli:suite": "vitest run --config src/server/vitest.config.ts tests/sandbox/",
    "test:cd:cli:alias": "vitest run --config src/server/vitest.config.ts tests/sandbox/cli.test.ts -t \"routes dev aliases to local CLI for agent shortcuts\"",
    "test:cd:cli:e2e": "./scripts/cd-cli-e2e.sh",
    "test:sandbox:agent-flow": "./scripts/sandbox-agent-flow.sh",
    "test:sandbox:agent-prepublish": "npm run test:sandbox:agent-flow",
    "nuke": "node ./bin/auramaxx.js nuke --yes",
    "sandbox": "./scripts/sandbox.sh terminal",
    "sandbox:dev": "./scripts/sandbox.sh terminal --dev",
    "sandbox:dashboard": "./scripts/sandbox.sh dashboard",
    "sandbox:dashboard:dev": "./scripts/sandbox.sh dashboard --dev",
    "sandbox:mcp": "./scripts/sandbox.sh mcp",
    "sandbox:agent": "./scripts/sandbox.sh agent",
    "desktop": "electron apps/desktop-electron/main.js",
    "desktop:build": "electron-builder --config apps/desktop-electron/electron-builder.yml",
    "desktop:build:mac": "electron-builder --config apps/desktop-electron/electron-builder.yml --mac",
    "desktop:build:win": "electron-builder --config apps/desktop-electron/electron-builder.yml --win",
    "desktop:build:linux": "electron-builder --config apps/desktop-electron/electron-builder.yml --linux",
    "security:protected-gate": "python3 scripts/task_queue.py protected-gate",
    "security:protected-gate:strict": "python3 scripts/task_queue.py protected-gate --fail-on-touch",
    "security:install-hooks": "./scripts/install-git-hooks.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@eslint/eslintrc": "^3.3.3",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@prisma/client": "^5.22.0",
    "@simplewebauthn/server": "^11.0.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.95.4",
    "@types/multer": "^2.0.0",
    "@whetstone-research/doppler-sdk": "^0.0.17",
    "autoprefixer": "^10.4.24",
    "better-sqlite3": "^12.6.2",
    "bip39": "^3.1.0",
    "cbor-x": "^1.6.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "ed25519-hd-key": "^1.3.0",
    "ethers": "^6.13.4",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "lucide-react": "^0.468.0",
    "marked": "^17.0.2",
    "multer": "^2.0.2",
    "next": "^15.5.11",
    "openai": "^6.21.0",
    "otpauth": "^9.5.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "uuid": "^11.0.4",
    "viem": "^2.45.1",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.1.4",
    "jsdom": "^28.0.0",
    "supertest": "^7.2.2",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  }
}
